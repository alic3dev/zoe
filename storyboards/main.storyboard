<?xml version="1.0" encoding="UTF-8"?>
<document
  type="com.apple.InterfaceBuilder3.Cocoa.Storyboard.XIB"
  version="3.0"
  toolsVersion="14490.64"
  targetRuntime="MacOSX.Cocoa"
  propertyAccessControl="none"
  initialViewController="windowcontroller-core"
  initialFirstResponder="view-view-core"
>
  <scenes>
    <scene
      sceneID="scene-menu"
    >
      <objects>
        <application
          id="application-menu"
          sceneMemberID="viewController"
          customClass="zoe_application"
        >
          <menu
            id="menu-core"
            key="mainMenu"
            title="zoe:core"
            systemMenu="main"
          >
            <items>
              <menuItem
                id="menuitem-core"
                title="zoe"
              >
                <modifierMask
                  key="keyEquivalentModifierMask"
                />

                <menu
                  id="menu-core-zoe"
                  key="submenu"
                  title="zoe"
                  systemMenu="apple"
                >
                  <items>
                    <menuItem
                      id="menuitem-core-zoe-item-terminate"
                      title="quit->{zoe}"
                      keyEquivalent="q"
                    >
                      <connections>
                        <action
                          id="action-core-zoe-terminate-action"
                          selector="terminate:"
                          target="first-responder-menu-core-terminate"
                        />
                      </connections>
                    </menuItem>
                  </items>
                </menu>
              </menuItem>
            </items>
          </menu>
        </application>

        <customObject
          id="first-responder-menu-core-terminate"
          userLabel="First Responder"
          customClass="NSResponder"
          sceneMemberID="firstResponder"
        />
      </objects>

      <point
        key="canvasLocation"
        x="75"
        y="0.0"
      />
    </scene>

    <scene sceneID="scene-window">
      <objects>
        <windowController
          id="windowcontroller-core"
          sceneMemberID="viewController"
        >
          <window
            id="window-core"
            key="window"
            title="zoe"
            allowsToolTipsWhenApplicationIsInactive="0"
            autorecalculatesKeyViewLoop="0"
            releasedWhenClosed="0"
            animationBehavior="none"
            userLabel="zoe"
            customClass="zoe_window"
          >
            <windowStyleMask
              key="styleMask"
              borderless="1"
              titled="0"
              resizable="1"
            />

            <rect
              key="contentRect"
              width="1"
              height="1"
            />
            <rect
              key="screenRect"
              width="1"
              height="1"
            />

            <connections>
              <outlet
                id="outlet-window-core"
                property="delegate"
                destination="windowcontroller-core"
              />
            </connections>
          </window>

          <connections>
            <segue
              id="segue-window-core"
              kind="relationship"
              relationship="window.shadowedContentViewController"
              destination="viewcontroller-view-core"
            />
          </connections>
        </windowController>
      </objects>
    </scene>

    <scene
      sceneID="scene-view"
    >
      <objects>
        <viewController
          id="viewcontroller-view-core"
          customClass="zoe_view_controller"
          sceneMemberID="viewController"
        >
          <view
            id="view-view-core"
            key="view"
            customClass="zoe_view"
          >
            <rect
              key="frame"
              width="1280"
              height="720"
            />
          </view>
        </viewController>
      </objects>
    </scene>
  </scenes>
</document>
